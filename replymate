<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ReplyMate</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', sans-serif; background: #f5f6fa; color: #1a1a2e; }

  header { background: #fff; border-bottom: 1px solid #e0e0e0; padding: 14px 28px; display: flex; align-items: center; justify-content: space-between; }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-icon { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border-radius: 10px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .logo-text { font-weight: 800; font-size: 20px; color: #1a1a2e; }
  .logo-sub { font-size: 12px; color: #888; }
  .badge-pro { background: #ede9fe; color: #4f46e5; border-radius: 20px; padding: 3px 10px; font-size: 12px; font-weight: 700; }

  .stats { display: flex; gap: 16px; padding: 20px 28px; }
  .stat { background: #fff; border-radius: 12px; padding: 16px 22px; flex: 1; border: 1px solid #e8e8f0; }
  .stat-val { font-size: 26px; font-weight: 800; color: #4f46e5; }
  .stat-label { font-size: 12px; color: #888; margin-top: 2px; }

  .main { display: grid; grid-template-columns: 1fr 380px; gap: 20px; padding: 0 28px 28px; }

  .reviews-panel { background: #fff; border-radius: 14px; border: 1px solid #e8e8f0; overflow: hidden; }
  .panel-header { padding: 16px 20px; border-bottom: 1px solid #f0f0f0; display: flex; align-items: center; justify-content: space-between; }
  .panel-title { font-weight: 700; font-size: 15px; }
  .filter-tabs { display: flex; gap: 6px; }
  .ftab { padding: 5px 12px; border-radius: 20px; border: 1px solid #e0e0e0; background: #fff; font-size: 12px; cursor: pointer; font-weight: 600; color: #888; }
  .ftab.active { background: #4f46e5; color: #fff; border-color: #4f46e5; }

  .review-item { padding: 16px 20px; border-bottom: 1px solid #f5f5f5; cursor: pointer; transition: background 0.15s; }
  .review-item:hover { background: #fafafa; }
  .review-item.selected { background: #f0f0ff; border-left: 3px solid #4f46e5; }
  .review-item.urgent { border-left: 3px solid #ef4444; }
  .review-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px; }
  .reviewer { font-weight: 700; font-size: 14px; }
  .review-meta { display: flex; gap: 8px; align-items: center; }
  .stars { color: #f59e0b; font-size: 13px; }
  .platform-badge { font-size: 10px; padding: 2px 7px; border-radius: 10px; font-weight: 700; }
  .google { background: #fef2f2; color: #dc2626; }
  .facebook { background: #eff6ff; color: #2563eb; }
  .yelp { background: #fff7ed; color: #ea580c; }
  .review-text { font-size: 13px; color: #555; line-height: 1.5; margin-bottom: 8px; }
  .review-footer { display: flex; justify-content: space-between; align-items: center; }
  .time-ago { font-size: 11px; color: #bbb; }
  .status-pill { font-size: 10px; padding: 2px 8px; border-radius: 10px; font-weight: 700; }
  .unanswered { background: #fef2f2; color: #dc2626; }
  .replied { background: #f0fdf4; color: #16a34a; }

  .reply-panel { background: #fff; border-radius: 14px; border: 1px solid #e8e8f0; display: flex; flex-direction: column; }
  .rp-header { padding: 16px 20px; border-bottom: 1px solid #f0f0f0; }
  .rp-title { font-weight: 700; font-size: 15px; margin-bottom: 4px; }
  .rp-sub { font-size: 12px; color: #888; }
  .rp-body { padding: 16px 20px; flex: 1; display: flex; flex-direction: column; gap: 14px; }

  .tone-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .tone-btn { padding: 5px 12px; border-radius: 20px; border: 1px solid #e0e0e0; background: #fff; font-size: 12px; cursor: pointer; font-weight: 600; color: #555; transition: all 0.15s; }
  .tone-btn.active { background: #4f46e5; color: #fff; border-color: #4f46e5; }

  .ai-btn { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none; border-radius: 10px; padding: 11px; font-size: 14px; font-weight: 700; cursor: pointer; width: 100%; transition: opacity 0.2s; }
  .ai-btn:hover { opacity: 0.9; }
  .ai-btn:disabled { opacity: 0.5; cursor: wait; }

  .reply-box { width: 100%; border: 1px solid #e0e0e0; border-radius: 10px; padding: 12px; font-size: 13px; resize: none; font-family: inherit; color: #1a1a2e; line-height: 1.6; outline: none; transition: border-color 0.2s; }
  .reply-box:focus { border-color: #4f46e5; }

  .action-row { display: flex; gap: 8px; }
  .btn-secondary { flex: 1; padding: 10px; border-radius: 10px; border: 1px solid #e0e0e0; background: #fff; font-size: 13px; font-weight: 600; cursor: pointer; color: #555; }
  .btn-primary { flex: 2; padding: 10px; border-radius: 10px; border: none; background: #16a34a; color: #fff; font-size: 13px; font-weight: 700; cursor: pointer; }
  .btn-primary:hover { background: #15803d; }

  .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 40px; text-align: center; color: #bbb; gap: 10px; }
  .empty-icon { font-size: 40px; }

  .toast { position: fixed; bottom: 24px; right: 24px; background: #1a1a2e; color: #fff; padding: 12px 20px; border-radius: 10px; font-size: 13px; font-weight: 600; opacity: 0; transition: opacity 0.3s; pointer-events: none; z-index: 999; }
  .toast.show { opacity: 1; }

  label { font-size: 12px; font-weight: 700; color: #888; display: block; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">💬</div>
    <div>
      <div class="logo-text">ReplyMate</div>
      <div class="logo-sub">AI Review Manager</div>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:12px;">
    <span style="font-size:13px;color:#888;">🏪 Mario's Pizza & Grill</span>
    <span class="badge-pro">PRO</span>
  </div>
</header>

<div class="stats">
  <div class="stat"><div class="stat-val" id="s-pending">5</div><div class="stat-label">Pending Replies</div></div>
  <div class="stat"><div class="stat-val" style="color:#16a34a;" id="s-replied">12</div><div class="stat-label">Replied This Week</div></div>
  <div class="stat"><div class="stat-val" style="color:#f59e0b;">4.6 ⭐</div><div class="stat-label">Avg Rating</div></div>
  <div class="stat"><div class="stat-val" style="color:#7c3aed;">2.4h</div><div class="stat-label">Time Saved This Week</div></div>
</div>

<div class="main">
  <div class="reviews-panel">
    <div class="panel-header">
      <span class="panel-title">Recent Reviews</span>
      <div class="filter-tabs">
        <button class="ftab active" onclick="filterReviews('all', this)">All</button>
        <button class="ftab" onclick="filterReviews('unanswered', this)">Unanswered</button>
        <button class="ftab" onclick="filterReviews('replied', this)">Replied</button>
      </div>
    </div>
    <div id="reviews-list"></div>
  </div>

  <div class="reply-panel">
    <div class="rp-header">
      <div class="rp-title">✨ AI Reply Generator</div>
      <div class="rp-sub">Select a review to generate a reply</div>
    </div>
    <div class="rp-body" id="reply-body">
      <div class="empty-state">
        <div class="empty-icon">👈</div>
        <div style="font-weight:700;color:#aaa;">Select a review</div>
        <div style="font-size:13px;">Click any review to generate an AI-powered reply in seconds.</div>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
var reviews = [
  { id:1, name:"Sarah M.", stars:1, platform:"google", text:"Waited 45 minutes for cold pizza. Nobody apologized. Won't be back. Terrible experience all around.", time:"2 hours ago", status:"unanswered", urgent:true },
  { id:2, name:"James T.", stars:5, platform:"google", text:"Best pizza in the neighbourhood! The margherita was perfect and staff were so friendly. Already planning my next visit!", time:"4 hours ago", status:"unanswered", urgent:false },
  { id:3, name:"Linda K.", stars:2, platform:"yelp", text:"Food was okay but the service was really slow. Had to ask three times for water. The pasta tasted great though.", time:"Yesterday", status:"unanswered", urgent:true },
  { id:4, name:"Tom R.", stars:5, platform:"facebook", text:"Hosted our company lunch here — they accommodated 15 people last minute and the food was outstanding. Highly recommend!", time:"Yesterday", status:"replied", urgent:false },
  { id:5, name:"Priya N.", stars:3, platform:"google", text:"Decent food, average prices. Nothing special but nothing bad either. Might come back to try the wood-fired options.", time:"2 days ago", status:"unanswered", urgent:false },
  { id:6, name:"Mike D.", stars:4, platform:"yelp", text:"Great atmosphere and the garlic bread is to die for. Service was a bit slow on a Friday night but understandable.", time:"3 days ago", status:"replied", urgent:false }
];

var selected = null;
var currentFilter = "all";
var tone = "professional";

var replies = {
  1: {
    professional: "Dear Sarah, thank you for taking the time to share your feedback. We sincerely apologize for the unacceptable wait time and the cold food you received — this is not the standard we hold ourselves to. We have shared your feedback directly with our kitchen and service team. We would love the opportunity to make this right and invite you back for a complimentary meal. Please reach out to us directly at marios@example.com.",
    friendly: "Hi Sarah! We're really sorry to hear about your experience — that's not us at all and we completely understand your frustration. Cold pizza after a 45-minute wait is absolutely not okay, and we're embarrassed it happened. We'd love a chance to turn this around for you. Please message us and we'll sort something out! 🍕",
    apologetic: "Dear Sarah, we are truly sorry. A 45-minute wait followed by cold food and no apology is inexcusable, and we take full responsibility. Your experience has been raised with our entire team as an urgent priority. Please give us one more chance — we would like to offer you a full complimentary meal and personally ensure your next visit is everything it should be.",
    brief: "Hi Sarah, we're truly sorry for your experience. Cold food and a long wait is unacceptable. Please contact us directly — we'd like to make it right."
  },
  2: {
    professional: "Thank you so much for your wonderful review, James! We're thrilled to hear you enjoyed the margherita and that our team made you feel welcome. Kind words like yours mean the world to us. We look forward to seeing you again soon!",
    friendly: "James, this absolutely made our day! 🍕❤️ So glad the margherita hit the spot and that you had a great time with us. We can't wait to see you back — next time you have to try the tiramisu!",
    apologetic: "Thank you so much for the kind words, James! We're delighted you had a great experience with us.",
    brief: "Thank you James! So glad you loved the margherita. See you next time! 🍕"
  },
  3: {
    professional: "Dear Linda, thank you for your honest feedback. We apologize for the slow service and the difficulty in getting water — that falls short of our standards. We're glad the pasta was enjoyable, and we have taken note of your service feedback for our team. We hope to welcome you back and show you a much improved experience.",
    friendly: "Hi Linda! Thanks for being honest with us — we're sorry the service let you down, especially having to ask multiple times for water. That's not how we want anyone to feel! Really glad the pasta made up for it a little though 😊 We'd love to have you back!",
    apologetic: "Dear Linda, we sincerely apologize for the service you experienced. Having to ask repeatedly for water is something that should never happen, and we are sorry for making your visit uncomfortable. We are addressing this with our team immediately. We truly hope you'll give us another chance.",
    brief: "Hi Linda, sorry about the slow service — that's not good enough. Glad the pasta was tasty! We'd love to do better next visit."
  },
  4: {
    professional: "Thank you for choosing us for your company lunch, Tom! We're so pleased we could accommodate your group and that the food exceeded expectations. We hope to see you and your team again soon!",
    friendly: "Tom, wow — thank you! 🙌 Hosting 15 people is always a challenge and we're so glad it all came together. Your team is welcome back any time!",
    apologetic: "Thank you so much for the kind words, Tom! We're really glad it all worked out for your team.",
    brief: "Thanks Tom! So glad we could make it work. Hope to see the team again soon!"
  },
  5: {
    professional: "Thank you for dining with us, Priya, and for leaving your honest review. We'd love for you to try our wood-fired options on your next visit — we think they might exceed expectations! We hope to welcome you back soon.",
    friendly: "Thanks Priya! We appreciate the honest review 😊 You HAVE to try the wood-fired pizza next time — it's a whole different experience! Hope to see you back soon!",
    apologetic: "Thank you for the review, Priya. We appreciate your honest feedback and hope to impress you more next time.",
    brief: "Thanks Priya! Definitely try the wood-fired menu next time — hope to see you soon!"
  },
  6: {
    professional: "Thank you for the kind words, Mike! We're glad you enjoyed the atmosphere and the garlic bread. Friday nights do get busy — we appreciate your understanding and look forward to seeing you again!",
    friendly: "Mike, the garlic bread fan club thanks you! 🧄😄 Fridays are wild but we love the energy. Hope to see you back soon — maybe on a quieter night!",
    apologetic: "Thank you for your review, Mike! We're sorry the wait frustrated you on Friday — we're working on improving our service speed during peak hours.",
    brief: "Thanks Mike! Glad you loved the garlic bread. See you again soon!"
  }
};

function starStr(n) {
  var s = "";
  for (var i = 0; i < n; i++) s += "★";
  for (var i = n; i < 5; i++) s += "☆";
  return s;
}

function renderReviews() {
  var list = document.getElementById("reviews-list");
  var filtered = reviews.filter(function(r) {
    if (currentFilter === "all") return true;
    return r.status === currentFilter;
  });
  list.innerHTML = filtered.map(function(r) {
    var isSelected = selected && selected.id === r.id;
    var classes = "review-item" + (r.urgent && r.status === "unanswered" ? " urgent" : "") + (isSelected ? " selected" : "");
    return '<div class="' + classes + '" onclick="selectReview(' + r.id + ')">' +
      '<div class="review-top">' +
        '<div class="reviewer">' + r.name + '</div>' +
        '<div class="review-meta">' +
          '<span class="stars">' + starStr(r.stars) + '</span>' +
          '<span class="platform-badge ' + r.platform + '">' + r.platform.charAt(0).toUpperCase() + r.platform.slice(1) + '</span>' +
        '</div>' +
      '</div>' +
      '<div class="review-text">' + r.text + '</div>' +
      '<div class="review-footer">' +
        '<span class="time-ago">' + r.time + '</span>' +
        '<span class="status-pill ' + r.status + '">' + (r.status === "unanswered" ? "⚠ Unanswered" : "✓ Replied") + '</span>' +
      '</div>' +
    '</div>';
  }).join("");
}

function filterReviews(f, el) {
  currentFilter = f;
  document.querySelectorAll(".ftab").forEach(function(b) { b.classList.remove("active"); });
  el.classList.add("active");
  renderReviews();
}

function selectReview(id) {
  selected = null;
  for (var i = 0; i < reviews.length; i++) {
    if (reviews[i].id === id) { selected = reviews[i]; break; }
  }
  renderReviews();
  renderReplyPanel();
}

function renderReplyPanel() {
  if (!selected) return;
  var body = document.getElementById("reply-body");
  body.innerHTML =
    '<div><label>Tone</label>' +
    '<div class="tone-row">' +
      '<button class="tone-btn ' + (tone==="professional"?"active":"") + '" onclick="setTone(\'professional\',this)">💼 Professional</button>' +
      '<button class="tone-btn ' + (tone==="friendly"?"active":"") + '" onclick="setTone(\'friendly\',this)">😊 Friendly</button>' +
      '<button class="tone-btn ' + (tone==="apologetic"?"active":"") + '" onclick="setTone(\'apologetic\',this)">🙏 Apologetic</button>' +
      '<button class="tone-btn ' + (tone==="brief"?"active":"") + '" onclick="setTone(\'brief\',this)">⚡ Brief</button>' +
    '</div></div>' +
    '<button class="ai-btn" id="gen-btn" onclick="generateReply()">✨ Generate AI Reply</button>' +
    '<div><label>Reply</label><textarea class="reply-box" id="reply-text" rows="7" placeholder="Your reply will appear here..."></textarea></div>' +
    '<div class="action-row">' +
      '<button class="btn-secondary" onclick="generateReply()">🔄 Regenerate</button>' +
      '<button class="btn-primary" onclick="markReplied()">✓ Mark as Replied</button>' +
    '</div>' +
    '<div style="font-size:11px;color:#bbb;text-align:center;">Review before posting to your platform.</div>';
}

function setTone(t, el) {
  tone = t;
  document.querySelectorAll(".tone-btn").forEach(function(b) { b.classList.remove("active"); });
  el.classList.add("active");
}

function generateReply() {
  if (!selected) return;
  var btn = document.getElementById("gen-btn");
  var box = document.getElementById("reply-text");
  btn.disabled = true;
  btn.textContent = "Generating...";
  box.value = "";
  setTimeout(function() {
    var set = replies[selected.id];
    var reply = set ? (set[tone] || set.professional) : "Thank you for your review! We appreciate your feedback and look forward to serving you again.";
    typeReply(reply, box);
    btn.disabled = false;
    btn.textContent = "✨ Generate AI Reply";
  }, 900);
}

function typeReply(text, el) {
  var i = 0;
  el.value = "";
  var interval = setInterval(function() {
    el.value += text[i];
    i++;
    if (i >= text.length) clearInterval(interval);
  }, 12);
}

function markReplied() {
  if (!selected) return;
  for (var i = 0; i < reviews.length; i++) {
    if (reviews[i].id === selected.id) { reviews[i].status = "replied"; break; }
  }
  var pending = reviews.filter(function(r) { return r.status === "unanswered"; }).length;
  var replied = reviews.filter(function(r) { return r.status === "replied"; }).length;
  document.getElementById("s-pending").textContent = pending;
  document.getElementById("s-replied").textContent = replied;
  renderReviews();
  showToast("✓ Marked as replied!");
}

function showToast(msg) {
  var t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  setTimeout(function() { t.classList.remove("show"); }, 2500);
}

renderReviews();
</script>
</body>
</html>
